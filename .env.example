NODE_ID=node-1
NODE_HOST=0.0.0.0
NODE_PORT=8001

NODE_TYPE=lock

PEERS=node-2:127.0.0.1:8002,node-3:127.0.0.1:8003


DATA_DIR=./data

LOG_LEVEL=INFO

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_MAX_CONNECTIONS=10

ELECTION_TIMEOUT_MIN=0.15
ELECTION_TIMEOUT_MAX=0.30

HEARTBEAT_INTERVAL=0.05

RPC_TIMEOUT=0.10

MAX_LOG_ENTRIES_PER_RPC=100

SNAPSHOT_THRESHOLD=1000

#Distributed lock manager
LOCK_DEFAULT_TTL=30.0          
LOCK_MAX_TTL=300.0
LOCK_RETRY_INTERVAL=0.05       
DEADLOCK_DETECTION_INTERVAL=5.0

# Distributed Queue 
QUEUE_VIRTUAL_NODES=150        
QUEUE_REPLICATION_FACTOR=2     
MAX_MESSAGE_SIZE=1048576        
MESSAGE_TTL=86400               
ACK_TIMEOUT=30.0    

# Distributed Cache 
CACHE_MAX_SIZE=1000            
CACHE_TTL=300.0                
CACHE_REPLACEMENT_POLICY=LRU   
CACHE_COHERENCE_PROTOCOL=MESI  
CACHE_METRICS_INTERVAL=10.0    